/**
 * Return an array of arrays of size *returnSize.
 * The sizes of the arrays are returned as *returnColumnSizes array.
 * Note: Both returned array and *columnSizes array must be malloced, assume caller calls free().
 */
void backtrack(int* candidates, int candidatesSize, int target, int start, 
               int* current, int currentSize, int** result, int* returnSize, 
               int** returnColumnSizes) {
    if (target == 0) {
        // Found a valid combination
        result[*returnSize] = (int*)malloc(currentSize * sizeof(int));
        for (int i = 0; i < currentSize; i++) {
            result[*returnSize][i] = current[i];
        }
        (*returnColumnSizes)[*returnSize] = currentSize;
        (*returnSize)++;
        return;
    }
    
    for (int i = start; i < candidatesSize; i++) {
        if (candidates[i] > target) {
            // Since candidates are sorted, we can break if current number exceeds target
            continue;
        }
        
        // Choose the current candidate
        current[currentSize] = candidates[i];
        
        // Recurse with the same index i (since we can reuse the same number)
        backtrack(candidates, candidatesSize, target - candidates[i], i, 
                 current, currentSize + 1, result, returnSize, returnColumnSizes);
    }
}

int** combinationSum(int* candidates, int candidatesSize, int target, int* returnSize, int** returnColumnSizes) {
    // Sort the candidates array first
    for (int i = 0; i < candidatesSize - 1; i++) {
        for (int j = 0; j < candidatesSize - i - 1; j++) {
            if (candidates[j] > candidates[j + 1]) {
                int temp = candidates[j];
                candidates[j] = candidates[j + 1];
                candidates[j + 1] = temp;
            }
        }
    }
    
    // Allocate memory for results
    int** result = (int**)malloc(150 * sizeof(int*));
    *returnColumnSizes = (int*)malloc(150 * sizeof(int));
    *returnSize = 0;
    
    // Temporary array to store current combination
    int* current = (int*)malloc(40 * sizeof(int)); // Maximum depth is target/min(candidates)
    
    // Start backtracking
    backtrack(candidates, candidatesSize, target, 0, current, 0, 
             result, returnSize, returnColumnSizes);
    
    free(current);
    return result;
}
